# ═══════════════════════════════════════════════════════════════════════════════
# SUPABASE (production / staging en ligne) — conserver dans `.env`
# Mot de passe : Dashboard Supabase → Project Settings → Database
# ═══════════════════════════════════════════════════════════════════════════════
SUPABASE_PROJECT_REF="kscqydofhvbkkkdwgbfh"
SUPABASE_URL="https://kscqydofhvbkkkdwgbfh.supabase.co"
NEXT_PUBLIC_SUPABASE_URL="https://kscqydofhvbkkkdwgbfh.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-or-publishable-key"

# Connexion poolée Supabase (runtime API) — port 6543
DATABASE_URL="postgresql://postgres.kscqydofhvbkkkdwgbfh:YOUR_DB_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Connexion directe Supabase (migrations Prisma) — port 5432
DIRECT_URL="postgresql://postgres.kscqydofhvbkkkdwgbfh:YOUR_DB_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# ═══════════════════════════════════════════════════════════════════════════════
# DÉVELOPPEMENT LOCAL — ne pas modifier `.env` : copiez `.env.local.example` → `.env.local`
# `.env.local` écrase DATABASE_URL, DIRECT_URL et NEXT_PUBLIC_API_URL en local.
# Voir `.env.local.example` pour les valeurs PostgreSQL Docker (audax / audax_secret).
# ═══════════════════════════════════════════════════════════════════════════════

# JWT
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_REFRESH_SECRET="change-me-refresh-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# API
API_PORT=4000
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
CORS_ORIGIN="http://localhost:3000"

# App
NEXT_PUBLIC_APP_NAME="AUDAX"
