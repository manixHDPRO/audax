# Copiez ce fichier en .env sur le VPS (ou utilisez scripts/deploy-vps.ps1)
# Remplacez YOUR_DB_PASSWORD et générez des secrets JWT forts avant le déploiement.
#
# TLS obligatoire : configurez d’abord deploy/nginx/audax.conf + Certbot (deploy/TLS.md),
# puis renseignez les URL HTTPS avec votre domaine.

SUPABASE_PROJECT_REF="your-supabase-project-ref"
SUPABASE_URL="https://your-supabase-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-or-publishable-key"

DATABASE_URL="postgresql://postgres.YOUR_REF:YOUR_DB_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR_REF:YOUR_DB_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# Obligatoire en production : ≥ 32 caractères, pas de placeholder
# Génération : openssl rand -base64 48
JWT_SECRET="paste-openssl-rand-base64-48-output-here-xxxxx"
JWT_REFRESH_SECRET="paste-another-openssl-rand-base64-48-here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

API_PORT=4000
# Port du frontend Audax (3001 si un autre projet utilise déjà 3000, ex. Scorpion)
AUDAX_WEB_PORT=3001
# URLs publiques — adapter le port si AUDAX_WEB_PORT ≠ 3000
NEXT_PUBLIC_API_URL="https://audax.example.com/api"
CORS_ORIGIN="https://audax.example.com"
PUBLIC_HOST="audax.example.com"

# Swagger désactivé automatiquement en production
ENABLE_SWAGGER=false

NEXT_PUBLIC_APP_NAME="AUDAX"

# E-mail (recommandé en production pour invitations / reset)
# APP_URL="https://audax.example.com"
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
