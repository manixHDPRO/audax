# Copiez ce fichier en `.env.local` à la racine du projet.
# `.env.local` est ignoré par git et ÉCRASE `.env` en développement local.
# Gardez `.env` intact avec vos paramètres Supabase pour le déploiement en ligne.

# ── Base PostgreSQL locale ─────────────────────────────────────────────────────
# Utilisateur postgres (ou audax après npm run db:setup). Encodage URL : @ → %40
DATABASE_URL="postgresql://postgres:VOTRE_MDP@localhost:5432/audax?schema=public"
DIRECT_URL="postgresql://postgres:VOTRE_MDP@localhost:5432/audax?schema=public"
# Exemple si le mot de passe est Mpro@123 :
# DATABASE_URL="postgresql://postgres:Mpro%40123@localhost:5432/audax?schema=public"

# ── API & front en local ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
CORS_ORIGIN="http://localhost:3000"
APP_URL="http://localhost:3000"

# ── E-mail (invitations et réinitialisation mot de passe) ───────────────────
# Si SMTP_HOST est absent, les liens sont affichés dans les logs de l'API.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="noreply@example.com"
# SMTP_PASS="votre-mot-de-passe-smtp"
# SMTP_FROM="AUDAX <noreply@example.com>"

# Les clés Supabase ci-dessous restent celles de `.env` si vous ne les redéfinissez pas ici.
# Pour tester sans Supabase Auth côté client, vous pouvez laisser NEXT_PUBLIC_SUPABASE_* telles quelles :
# l'app Audax utilise surtout l'API NestJS + JWT pour l'authentification.
